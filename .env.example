# QuickChat Backend — Environment Variables
# Copy to .env: cp .env.example .env

# ==========================================
# Application
# ==========================================
NODE_ENV=development
PORT=3002
API_PREFIX=api/v1
CORS_ORIGINS=http://localhost:3000

# ==========================================
# Database (PostgreSQL 18)
# ==========================================
DB_HOST=localhost
DB_PORT=5435
DB_USER=dev
DB_PASSWORD=quickchat_dev_2026
DB_NAME=quickchat
DATABASE_URL=postgresql://dev:quickchat_dev_2026@localhost:5434/quickchat?schema=public

# ==========================================
# Redis
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_URL=redis://localhost:6380

# ==========================================
# JWT Authentication
# ==========================================
JWT_SECRET=quickchat-jwt-secret-change-in-production-min-32-chars!!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=quickchat-refresh-secret-change-in-production-min-32!!
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# AWS S3 (multimedia storage)
# ==========================================
AWS_S3_BUCKET=quickchat-uploads
AWS_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ==========================================
# Giphy API (GIF search)
# ==========================================
GIPHY_API_KEY=

# ==========================================
# Socket.io
# ==========================================
WS_PORT=3002
WS_CORS_ORIGINS=http://localhost:3000

# ==========================================
# Sentry (error monitoring)
# ==========================================
SENTRY_DSN=

# ==========================================
# File upload limits
# ==========================================
MAX_IMAGE_SIZE_MB=10
MAX_VIDEO_SIZE_MB=50
MAX_AUDIO_SIZE_MB=25
MAX_FILE_SIZE_MB=25

# ==========================================
# Message settings
# ==========================================
MESSAGE_EDIT_TIME_LIMIT_MIN=15
MAX_PINNED_MESSAGES_PER_CONVERSATION=5
